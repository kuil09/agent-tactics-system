{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-tactics-system/schemas/state-patch.schema.json",
  "title": "StatePatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "patch_id",
    "issue_id",
    "actor_id",
    "base_state_version",
    "operations",
    "requires_lock",
    "verifier_required",
    "rollback_to_version"
  ],
  "properties": {
    "patch_id": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "base_state_version": {
      "type": "integer",
      "minimum": 0
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "op",
          "path",
          "value"
        ],
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "add",
              "replace",
              "remove"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "value": {}
        }
      }
    },
    "requires_lock": {
      "type": "boolean"
    },
    "verifier_required": {
      "type": "boolean"
    },
    "rollback_to_version": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    }
  }
}
